<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content="<%= csrfToken %>" />
    <title>Manage Customers | Trizodiac</title>
    <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
  </head>
  <body class="bg-zinc-950">
    <div class="min-h-screen">
      <header class="border-b border-white/10 bg-zinc-950/90">
        <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between">
          <div class="flex items-center justify-between">
            <a href="/dashboard" class="text-lg font-semibold text-white">Trizodiac Admin</a>
            <div class="flex items-center gap-3 lg:hidden">
              <img class="h-9 w-9 rounded-full border border-white/10 object-cover" src="<%= currentUser.avatar || 'https://www.gravatar.com/avatar/?d=mp' %>" alt="" referrerpolicy="no-referrer" />
            </div>
          </div>
          <nav class="flex flex-wrap items-center gap-2">
            <a class="rounded-md bg-white/10 px-3 py-2 text-sm font-medium text-white" href="/dashboard">Orders</a>
            <a class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" href="/inventory">Inventory</a>
            <a class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" href="/financial">Financial</a>
            <a class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" href="/admin">Users</a>
            <form method="post" action="/auth/logout">
              <button class="rounded-md border border-white/10 px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" type="submit">Sign out</button>
            </form>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:py-8">
        <section class="mb-6 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.2em] text-emerald-300">Orders</p>
            <h1 class="mt-3 text-3xl font-semibold tracking-normal text-white">Manage Customers</h1>
            <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-400">Maintain reusable receiver names, contacts, and shipping addresses for order creation.</p>
          </div>
          <a href="/dashboard" class="inline-flex min-h-11 items-center justify-center rounded-md border border-white/10 px-5 text-sm font-semibold text-zinc-200 transition hover:bg-white/10 hover:text-white">Back to Orders</a>
        </section>

        <section class="rounded-lg border border-white/10 bg-zinc-950">
          <form id="customer-form" class="grid gap-3 border-b border-white/10 px-5 py-4 lg:grid-cols-[1fr_180px_1.5fr_auto_auto]">
            <input id="customer-id" type="hidden" />
            <label class="block">
              <span class="sr-only">Customer name</span>
              <input id="customer-name" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white placeholder:text-zinc-500 outline-none focus:border-emerald-300" type="text" placeholder="Name" required />
            </label>
            <label class="block">
              <span class="sr-only">Contact</span>
              <input id="customer-contact" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white placeholder:text-zinc-500 outline-none focus:border-emerald-300" type="text" placeholder="Contact" required />
            </label>
            <label class="block">
              <span class="sr-only">Shipping address</span>
              <input id="customer-shipping-address" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white placeholder:text-zinc-500 outline-none focus:border-emerald-300" type="text" placeholder="Shipping address" required />
            </label>
            <button id="save-customer-button" class="rounded-md bg-emerald-400 px-4 py-2 text-sm font-semibold text-zinc-950 hover:bg-emerald-300" type="submit">Save Customer</button>
            <button id="cancel-customer-button" class="hidden rounded-md border border-white/10 px-4 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" type="button">Cancel</button>
          </form>
          <p id="customer-error" class="mx-5 mt-4 hidden rounded-md border border-red-400/30 bg-red-500/10 px-4 py-3 text-sm text-red-100"></p>
          <div class="overflow-x-auto p-5">
            <table class="min-w-full border-collapse bg-white text-zinc-950">
              <thead>
                <tr>
                  <th class="border border-zinc-300 px-3 py-2 text-left text-sm font-black uppercase">Name</th>
                  <th class="border border-zinc-300 px-3 py-2 text-left text-sm font-black uppercase">Contact</th>
                  <th class="border border-zinc-300 px-3 py-2 text-left text-sm font-black uppercase">Shipping Address</th>
                  <th class="border border-zinc-300 px-3 py-2 text-right text-sm font-black uppercase">Actions</th>
                </tr>
              </thead>
              <tbody id="customer-table-body"></tbody>
            </table>
            <div id="empty-customers" class="hidden px-5 py-8 text-center text-sm text-zinc-400">No customers yet.</div>
          </div>
        </section>
      </main>
    </div>

    <script id="customers-data" type="application/json"><%- customersJson %></script>
    <script src="/js/customers.js?v=<%= assetVersion %>"></script>
  </body>
</html>
