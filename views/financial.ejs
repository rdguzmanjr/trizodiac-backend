<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content="<%= csrfToken %>" />
    <title>Financial | Trizodiac</title>
    <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
  </head>
  <body class="bg-zinc-950">
    <div class="min-h-screen">
      <header class="border-b border-white/10 bg-zinc-950/90">
        <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between">
          <div class="flex items-center justify-between">
            <a href="/dashboard" class="text-lg font-semibold text-white">Trizodiac Admin</a>
            <div class="flex items-center gap-3 lg:hidden">
              <img class="h-9 w-9 rounded-full border border-white/10 object-cover" src="<%= currentUser.avatar || 'https://www.gravatar.com/avatar/?d=mp' %>" alt="" referrerpolicy="no-referrer" />
            </div>
          </div>
          <nav class="flex flex-wrap items-center gap-2">
            <a class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" href="/dashboard">Orders</a>
            <a class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" href="/inventory">Inventory</a>
            <a class="rounded-md bg-white/10 px-3 py-2 text-sm font-medium text-white" href="/financial">Financial</a>
            <a class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" href="/admin">Users</a>
            <form method="post" action="/auth/logout">
              <button class="rounded-md border border-white/10 px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" type="submit">Sign out</button>
            </form>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:py-8">
        <section class="mb-6 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.2em] text-emerald-300">Financial</p>
            <h1 class="mt-3 text-3xl font-semibold tracking-normal text-white">Financial Dashboard</h1>
            <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-400">Track manually entered financial records and monitor the running total.</p>
          </div>
          <button id="new-financial-button" class="inline-flex min-h-11 items-center justify-center rounded-md bg-emerald-400 px-5 text-sm font-semibold text-zinc-950 transition hover:bg-emerald-300 focus:outline-none focus:ring-2 focus:ring-emerald-200" type="button">
            New Record
          </button>
        </section>

        <section class="mb-5 grid gap-4 lg:grid-cols-[280px_1fr_160px]">
          <div class="rounded-lg border border-emerald-300/20 bg-emerald-400/10 px-5 py-4">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-200">Total</p>
            <p id="financial-total" class="mt-2 text-3xl font-semibold tracking-normal text-white">0.00</p>
          </div>
          <label class="block self-end">
            <span class="sr-only">Search financial records</span>
            <input id="financial-search" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white placeholder:text-zinc-500 outline-none transition focus:border-emerald-300" type="search" placeholder="Search description, date, added by, or price" />
          </label>
          <button id="clear-financial-search" class="min-h-11 self-end rounded-md border border-white/10 px-4 text-sm font-medium text-zinc-300 transition hover:bg-white/10 hover:text-white" type="button">Clear Search</button>
        </section>

        <section class="overflow-hidden rounded-lg border border-white/10 bg-zinc-950">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-white/10">
              <thead class="bg-white/[0.04]">
                <tr>
                  <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-400">Price</th>
                  <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-400">Description</th>
                  <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-400">Date</th>
                  <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-400">Added By</th>
                  <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wide text-zinc-400">Actions</th>
                </tr>
              </thead>
              <tbody id="financial-table-body" class="divide-y divide-white/10"></tbody>
            </table>
          </div>
          <div id="empty-financial" class="hidden px-5 py-12 text-center text-sm text-zinc-400">No financial records found.</div>
        </section>
      </main>
    </div>

    <div id="financial-modal" class="fixed inset-0 z-40 hidden items-center justify-center bg-black/70 p-4 opacity-0 transition-opacity duration-200">
      <div class="max-h-[92vh] w-full max-w-2xl overflow-hidden rounded-lg border border-white/10 bg-zinc-950 shadow-2xl shadow-black">
        <div class="flex items-center justify-between border-b border-white/10 px-5 py-4">
          <div>
            <h2 id="financial-modal-title" class="text-lg font-semibold text-white">New Financial Record</h2>
            <p class="text-sm text-zinc-400">Added By is set from your admin account.</p>
          </div>
          <button class="rounded-md px-3 py-2 text-sm text-zinc-400 hover:bg-white/10 hover:text-white" type="button" data-close-financial-modal>Close</button>
        </div>
        <form id="financial-form" class="max-h-[calc(92vh-84px)] overflow-y-auto px-5 py-5">
          <input type="hidden" id="financial-id" />
          <div class="grid gap-4 md:grid-cols-2">
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-zinc-300">Price</span>
              <input id="financial-price" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white outline-none focus:border-emerald-300" type="number" step="0.01" placeholder="Use negative values for expenses" required />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-zinc-300">Date</span>
              <input id="financial-date" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white outline-none focus:border-emerald-300" type="date" required />
            </label>
            <label class="block md:col-span-2">
              <span class="mb-1 block text-sm font-medium text-zinc-300">Description</span>
              <textarea id="financial-description" class="min-h-28 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-white outline-none focus:border-emerald-300" required></textarea>
            </label>
            <label class="block md:col-span-2">
              <span class="mb-1 block text-sm font-medium text-zinc-300">Added By</span>
              <input id="financial-added-by" data-current-admin="<%= currentUser.name || currentUser.email || 'Admin' %>" class="min-h-11 w-full rounded-md border border-white/10 bg-zinc-800 px-4 text-sm text-zinc-300 outline-none" type="text" value="<%= currentUser.name || currentUser.email || 'Admin' %>" readonly />
            </label>
          </div>

          <p id="financial-form-error" class="mt-4 hidden rounded-md border border-red-400/30 bg-red-500/10 px-4 py-3 text-sm text-red-100"></p>

          <div class="mt-6 flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
            <button class="rounded-md border border-white/10 px-5 py-3 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" type="button" data-close-financial-modal>Cancel</button>
            <button id="save-financial-button" class="rounded-md bg-emerald-400 px-5 py-3 text-sm font-semibold text-zinc-950 hover:bg-emerald-300 disabled:cursor-not-allowed disabled:opacity-60" type="submit">Save Record</button>
          </div>
        </form>
      </div>
    </div>

    <script id="financial-data" type="application/json"><%- recordsJson %></script>
    <script src="/js/financial.js?v=<%= assetVersion %>"></script>
  </body>
</html>
