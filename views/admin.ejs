<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Users | Trizodiac Admin</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="bg-zinc-950">
    <div class="min-h-screen">
      <header class="border-b border-white/10 bg-zinc-950/80">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
          <a href="/dashboard" class="text-lg font-semibold text-white">Trizodiac Admin</a>
          <nav class="flex items-center gap-2">
            <a class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" href="/dashboard">Dashboard</a>
            <form method="post" action="/auth/logout">
              <button class="rounded-md border border-white/10 px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" type="submit">Sign out</button>
            </form>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-7xl px-6 py-8">
        <div class="mb-8 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.2em] text-emerald-300">Access Control</p>
            <h1 class="mt-3 text-3xl font-semibold tracking-normal text-white">Admin Panel</h1>
          </div>

          <form class="flex w-full flex-col gap-3 sm:flex-row lg:w-auto" method="get" action="/admin">
            <input
              data-user-search
              class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white placeholder:text-zinc-500 outline-none focus:border-emerald-300 lg:w-80"
              type="search"
              name="search"
              value="<%= search %>"
              placeholder="Search name or email"
            />
            <select class="min-h-11 rounded-md border border-white/10 bg-zinc-900 px-3 text-sm text-white outline-none focus:border-emerald-300" name="sort">
              <% ['name', 'email', 'created_at', 'last_login', 'is_admin'].forEach((column) => { %>
                <option value="<%= column %>" <%= sort === column ? 'selected' : '' %>><%= column.replace('_', ' ') %></option>
              <% }) %>
            </select>
            <select class="min-h-11 rounded-md border border-white/10 bg-zinc-900 px-3 text-sm text-white outline-none focus:border-emerald-300" name="direction">
              <option value="desc" <%= direction === 'desc' ? 'selected' : '' %>>Descending</option>
              <option value="asc" <%= direction === 'asc' ? 'selected' : '' %>>Ascending</option>
            </select>
            <button class="min-h-11 rounded-md bg-emerald-400 px-5 text-sm font-semibold text-zinc-950 hover:bg-emerald-300" type="submit">Apply</button>
          </form>
        </div>

        <% if (success && success.length) { %>
          <div class="mb-4 rounded-md border border-emerald-400/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100"><%= success[0] %></div>
        <% } %>

        <% if (error && error.length) { %>
          <div class="mb-4 rounded-md border border-red-400/30 bg-red-500/10 px-4 py-3 text-sm text-red-100"><%= error[0] %></div>
        <% } %>

        <div class="overflow-hidden rounded-lg border border-white/10">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-white/10">
              <thead class="bg-white/[0.04]">
                <tr>
                  <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-400">User</th>
                  <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-400">Email</th>
                  <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-400">Date Created</th>
                  <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-400">Last Login</th>
                  <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-400">Admin Status</th>
                  <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wide text-zinc-400">Action</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/10 bg-zinc-950">
                <% users.forEach((user) => { %>
                  <tr>
                    <td class="px-5 py-4">
                      <div class="flex items-center gap-3">
                        <img class="h-10 w-10 rounded-full border border-white/10 object-cover" src="<%= user.avatar || 'https://www.gravatar.com/avatar/?d=mp' %>" alt="" referrerpolicy="no-referrer" />
                        <span class="max-w-48 truncate text-sm font-medium text-white"><%= user.name %></span>
                      </div>
                    </td>
                    <td class="px-5 py-4 text-sm text-zinc-300"><%= user.email %></td>
                    <td class="px-5 py-4 text-sm text-zinc-300"><%= new Date(user.created_at).toLocaleString() %></td>
                    <td class="px-5 py-4 text-sm text-zinc-300"><%= user.last_login ? new Date(user.last_login).toLocaleString() : 'Never' %></td>
                    <td class="px-5 py-4">
                      <% if (user.is_admin) { %>
                        <span class="rounded-full border border-emerald-300/30 bg-emerald-400/10 px-2.5 py-1 text-xs font-semibold text-emerald-200">Admin</span>
                      <% } else { %>
                        <span class="rounded-full border border-zinc-500/30 bg-zinc-500/10 px-2.5 py-1 text-xs font-semibold text-zinc-300">User</span>
                      <% } %>
                    </td>
                    <td class="px-5 py-4 text-right">
                      <% if (user.is_admin) { %>
                        <form method="post" action="/admin/users/<%= user.id %>/demote">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button class="rounded-md border border-red-400/30 px-3 py-2 text-sm font-medium text-red-100 hover:bg-red-500/10" type="submit">Remove Admin</button>
                        </form>
                      <% } else { %>
                        <form method="post" action="/admin/users/<%= user.id %>/promote">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button class="rounded-md border border-emerald-300/30 px-3 py-2 text-sm font-medium text-emerald-100 hover:bg-emerald-500/10" type="submit">Promote</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>

                <% if (!users.length) { %>
                  <tr>
                    <td colspan="6" class="px-5 py-10 text-center text-sm text-zinc-400">No users found.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
    <script src="/js/admin.js"></script>
  </body>
</html>
