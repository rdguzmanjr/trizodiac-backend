<article id="waybill-label" class="waybill-label" aria-label="Generated shipping label">
  <section class="waybill-header">
    <div class="waybill-brand">TRIZODIAC</div>
    <div class="waybill-subtitle">THANK YOU FOR YOUR ORDER!</div>
  </section>

  <section class="waybill-order-row">
    <div class="waybill-field">
      <span>ORDER #:</span>
      <strong data-label-field="order_number"></strong>
    </div>
    <div class="waybill-field">
      <span>DATE:</span>
      <strong data-label-field="order_date_display"></strong>
    </div>
  </section>

  <section class="waybill-section waybill-receiver">
    <div class="waybill-section-title">RECEIVER:</div>
    <div class="waybill-value" data-label-field="receiver"></div>
  </section>

  <section class="waybill-section waybill-address">
    <div class="waybill-section-title">ADDRESS:</div>
    <div class="waybill-value" data-label-field="address"></div>
  </section>

  <section class="waybill-section waybill-items">
    <div class="waybill-section-title">ITEMS:</div>
    <div class="waybill-value" data-label-field="items"></div>
  </section>

  <section class="waybill-payment-row">
    <div class="waybill-section">
      <div class="waybill-section-title">PAYMENT:</div>
      <div class="waybill-value" data-label-field="payment"></div>
    </div>
    <div class="waybill-section">
      <div class="waybill-section-title">TOTAL:</div>
      <div class="waybill-value" data-label-field="total_display"></div>
    </div>
  </section>

  <section class="waybill-section waybill-notes">
    <div class="waybill-section-title">NOTES:</div>
    <div class="waybill-value" data-label-field="notes"></div>
  </section>

  <section class="waybill-barcode-wrap">
    <div class="waybill-barcode" data-label-field="barcode_svg"></div>
    <div class="waybill-barcode-text" data-label-field="barcode_value"></div>
  </section>
</article>
