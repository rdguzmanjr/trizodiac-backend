<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content="<%= csrfToken %>" />
    <title>Inventory | Trizodiac</title>
    <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
  </head>
  <body class="bg-zinc-950">
    <div class="min-h-screen">
      <header class="border-b border-white/10 bg-zinc-950/90">
        <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between">
          <div class="flex items-center justify-between">
            <a href="/dashboard" class="text-lg font-semibold text-white">Trizodiac Admin</a>
            <div class="flex items-center gap-3 lg:hidden">
              <img class="h-9 w-9 rounded-full border border-white/10 object-cover" src="<%= currentUser.avatar || 'https://www.gravatar.com/avatar/?d=mp' %>" alt="" referrerpolicy="no-referrer" />
            </div>
          </div>
          <nav class="flex flex-wrap items-center gap-2">
            <a class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" href="/dashboard">Orders</a>
            <a class="rounded-md bg-white/10 px-3 py-2 text-sm font-medium text-white" href="/inventory">Inventory</a>
            <a class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" href="/admin">Users</a>
            <a class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" href="/settings">Settings</a>
            <form method="post" action="/auth/logout">
              <button class="rounded-md border border-white/10 px-3 py-2 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" type="submit">Sign out</button>
            </form>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:py-8">
        <section class="mb-6 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.2em] text-emerald-300">Inventory</p>
            <h1 class="mt-3 text-3xl font-semibold tracking-normal text-white">Inventory Dashboard</h1>
            <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-400">Track purchased bundle sets, item codes, specifications, sizes, lengths, and pricing.</p>
          </div>
          <button id="new-inventory-button" class="inline-flex min-h-11 items-center justify-center rounded-md bg-emerald-400 px-5 text-sm font-semibold text-zinc-950 transition hover:bg-emerald-300 focus:outline-none focus:ring-2 focus:ring-emerald-200" type="button">
            New Entry
          </button>
        </section>

        <section class="mb-4 grid gap-3 lg:grid-cols-[1fr_160px]">
          <label class="block">
            <span class="sr-only">Search inventory</span>
            <input id="inventory-search" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white placeholder:text-zinc-500 outline-none transition focus:border-emerald-300" type="search" placeholder="Search bundle, code, product specification, size, length, or price" />
          </label>
          <button id="clear-inventory-search" class="min-h-11 rounded-md border border-white/10 px-4 text-sm font-medium text-zinc-300 transition hover:bg-white/10 hover:text-white" type="button">Clear Search</button>
        </section>

        <section class="overflow-hidden rounded-lg border border-white/10 bg-zinc-950">
          <div class="overflow-x-auto">
            <table class="min-w-full border-collapse">
              <thead class="bg-white text-zinc-950">
                <tr>
                  <th class="border border-zinc-300 px-3 py-2 text-left text-sm font-black uppercase tracking-normal">Bundle Name</th>
                  <th class="border border-zinc-300 px-3 py-2 text-left text-sm font-black uppercase tracking-normal">Code #</th>
                  <th class="border border-zinc-300 px-3 py-2 text-left text-sm font-black uppercase tracking-normal">Product Specification</th>
                  <th class="border border-zinc-300 px-3 py-2 text-left text-sm font-black uppercase tracking-normal">Size</th>
                  <th class="border border-zinc-300 px-3 py-2 text-left text-sm font-black uppercase tracking-normal">Length</th>
                  <th class="border border-zinc-300 px-3 py-2 text-left text-sm font-black uppercase tracking-normal">Price</th>
                  <th class="border border-zinc-300 px-3 py-2 text-right text-sm font-black uppercase tracking-normal">Actions</th>
                </tr>
              </thead>
              <tbody id="inventory-table-body" class="bg-white text-zinc-950"></tbody>
            </table>
          </div>
          <div id="empty-inventory" class="hidden bg-zinc-950 px-5 py-12 text-center text-sm text-zinc-400">No inventory entries found.</div>
        </section>
      </main>
    </div>

    <div id="inventory-modal" class="fixed inset-0 z-40 hidden items-center justify-center bg-black/70 p-4 opacity-0 transition-opacity duration-200">
      <div class="max-h-[92vh] w-full max-w-3xl overflow-hidden rounded-lg border border-white/10 bg-zinc-950 shadow-2xl shadow-black">
        <div class="flex items-center justify-between border-b border-white/10 px-5 py-4">
          <div>
            <h2 id="inventory-modal-title" class="text-lg font-semibold text-white">New Inventory Entry</h2>
            <p class="text-sm text-zinc-400">Add one spreadsheet row to the inventory list.</p>
          </div>
          <button class="rounded-md px-3 py-2 text-sm text-zinc-400 hover:bg-white/10 hover:text-white" type="button" data-close-inventory-modal>Close</button>
        </div>
        <form id="inventory-form" class="max-h-[calc(92vh-84px)] overflow-y-auto px-5 py-5">
          <input type="hidden" id="inventory-id" />
          <div class="grid gap-4 md:grid-cols-2">
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-zinc-300">Bundle Name</span>
              <input id="bundle-name" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white outline-none focus:border-emerald-300" type="text" required />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-zinc-300">Code #</span>
              <input id="code-number" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white outline-none focus:border-emerald-300" type="text" required />
            </label>
            <label class="block md:col-span-2">
              <span class="mb-1 block text-sm font-medium text-zinc-300">Product Specification</span>
              <input id="product-specification" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white outline-none focus:border-emerald-300" type="text" required />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-zinc-300">Size in Inches</span>
              <input id="size-inches" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white outline-none focus:border-emerald-300" type="text" placeholder="32 inch" required />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-zinc-300">Length in Inches</span>
              <input id="length-inches" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white outline-none focus:border-emerald-300" type="text" placeholder="41 inch" required />
            </label>
            <label class="block md:col-span-2">
              <span class="mb-1 block text-sm font-medium text-zinc-300">Price</span>
              <input id="price" class="min-h-11 w-full rounded-md border border-white/10 bg-white/[0.04] px-4 text-sm text-white outline-none focus:border-emerald-300" type="text" placeholder="450 - 500" required />
            </label>
          </div>

          <p id="inventory-form-error" class="mt-4 hidden rounded-md border border-red-400/30 bg-red-500/10 px-4 py-3 text-sm text-red-100"></p>

          <div class="mt-6 flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
            <button class="rounded-md border border-white/10 px-5 py-3 text-sm font-medium text-zinc-300 hover:bg-white/10 hover:text-white" type="button" data-close-inventory-modal>Cancel</button>
            <button id="save-inventory-button" class="rounded-md bg-emerald-400 px-5 py-3 text-sm font-semibold text-zinc-950 hover:bg-emerald-300 disabled:cursor-not-allowed disabled:opacity-60" type="submit">Save Entry</button>
          </div>
        </form>
      </div>
    </div>

    <script id="inventory-data" type="application/json"><%- entriesJson %></script>
    <script src="/js/inventory.js?v=<%= assetVersion %>"></script>
  </body>
</html>
